default_platform(:ios)

platform :ios do
  desc "Fetch App Store signing certificates and profiles via Match"
  lane :sync_certs do
    app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      app_identifier: ["com.icareeye.app", "com.icareeye.app.watchkitapp"],
      readonly: is_ci
    )
  end

  desc "Build and upload to App Store Connect"
  lane :release do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: true
    )

    match(
      type: "appstore",
      app_identifier: ["com.icareeye.app", "com.icareeye.app.watchkitapp"],
      readonly: true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "3BGHPQ6C3H",
      code_sign_identity: "Apple Distribution",
      targets: ["iCare"],
      profile_name: "match AppStore com.icareeye.app",
      bundle_identifier: "com.icareeye.app"
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      team_id: "3BGHPQ6C3H",
      code_sign_identity: "Apple Distribution",
      targets: ["iCareWatch"],
      profile_name: "match AppStore com.icareeye.app.watchkitapp",
      bundle_identifier: "com.icareeye.app.watchkitapp"
    )

    version = ENV["APP_VERSION"] || "1.0.0"
    build_number = Time.now.strftime("%Y%m%d%H%M")

    increment_version_number(
      version_number: version,
      xcodeproj: "iCare.xcodeproj"
    )

    increment_build_number(
      build_number: build_number,
      xcodeproj: "iCare.xcodeproj"
    )

    gym(
      scheme: "iCare",
      export_method: "app-store",
      output_directory: "./build",
      output_name: "iCare.ipa",
      clean: true,
      export_options: {
        provisioningProfiles: {
          "com.icareeye.app" => "match AppStore com.icareeye.app",
          "com.icareeye.app.watchkitapp" => "match AppStore com.icareeye.app.watchkitapp"
        }
      }
    )

    deliver(
      api_key: api_key,
      ipa: "./build/iCare.ipa",
      skip_metadata: true,
      skip_screenshots: true,
      submit_for_review: false,
      precheck_include_in_app_purchases: false,
      force: true
    )
  end
end
